FLASK_ENV=development
DATABASE_URL=sqlite:///vehiclegrade.db

# Production only (Railway sets these automatically or via dashboard env vars):
# PORT=5001
# FLASK_DEBUG=false
# ALLOWED_ORIGINS=https://vehiclegrade.com,https://www.vehiclegrade.com

# Optional: leave unset to keep the AI explanation layer off (deterministic
# reports still work fully without any of these). Set one provider + its key
# to activate it - no code changes needed.
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
